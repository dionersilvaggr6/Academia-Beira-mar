# Supabase — base de dados (Session Pooler connection string), usada na Fase 1
DATABASE_URL="postgresql://user:password@host:5432/postgres"

# Supabase Auth (Fase 2A) — obter em Supabase → Settings → API
NEXT_PUBLIC_SUPABASE_URL="https://<projeto>.supabase.co"
NEXT_PUBLIC_SUPABASE_ANON_KEY="<anon / publishable key — pública>"
# SECRETO — só no servidor, nunca commitar, nunca NEXT_PUBLIC:
SUPABASE_SERVICE_ROLE_KEY="<service role key>"

# Opcional — força a origin usada no redirectTo dos convites e nos back_urls
# do checkout (ex.: produção atrás de um proxy sem x-forwarded-proto). Sem
# isto, deriva-se do host do pedido (funciona em localhost e previews da
# Vercel automaticamente).
# NEXT_PUBLIC_SITE_URL="https://academiabeiramar.com.br"

# Pagamento — Mercado Pago (checkout). Sem estas variáveis, o checkout cai
# sempre no fallback "recebemos seu pedido" (nunca quebra). Ver
# docs/mercadopago-teste.md para onde obter cada valor e como testar.
PAYMENT_PROVIDER="mercadopago"
# Access Token de TESTE (começa por "TEST-") — nunca o token de produção aqui.
MP_ACCESS_TOKEN="TEST-..."
# Segredo usado para validar a assinatura (x-signature) do webhook — obtido
# junto do Access Token, na mesma aplicação de teste do dashboard.
MP_WEBHOOK_SECRET="..."
